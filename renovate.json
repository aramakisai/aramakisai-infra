{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "automerge": false,
  "schedule": [
    "before 6am on monday"
  ],
  "ignorePaths": [
    "ansible/inventory/**"
  ],
  "terraform": {
    "managerFilePatterns": [
      "terraform/**/*.tf"
    ]
  },
  "github-actions": {
    "enabled": true
  },
  "kubernetes": {
    "managerFilePatterns": [
      "gitops/manifests/**/*.yaml"
    ]
  }
}
