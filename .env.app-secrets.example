# ============================================================
# .env.app-secrets — Infisical に登録するアプリシークレット
# ============================================================
# cp .env.app-secrets.example .env.app-secrets
# vi .env.app-secrets   # 実際の値を記入
#
# source .env && ./scripts/push-secrets-to-infisical.sh
#
# このファイルは ESO (ExternalSecret) が参照するキー名に合わせている。
# キー名を変更した場合は gitops/manifests/ の ExternalSecret も合わせて変更すること。
#
# ⚠ .env.app-secrets は .gitignore 済み。コミットしないこと。
# ============================================================

# ── Stalwart Mail Server ───────────────────────────────────
# 参照: gitops/manifests/prod/stalwart/external-secret.yaml
STALWART_ADMIN_SECRET=<管理者パスワード: openssl rand -base64 24>
# Cloudflare DNS-01 ACME チャレンジ用トークン
# Zone:DNS:Edit のみの最小権限トークンを発行すること (CLOUDFLARE_API_TOKEN とは別)
STALWART_CF_API_TOKEN=<Zone:DNS:Edit のみの Cloudflare API トークン>

# ── Directus (prod) ───────────────────────────────────────
# 参照: gitops/manifests/prod/directus/external-secret.yaml
DIRECTUS_SECRET=<ランダム文字列: openssl rand -base64 24>
DIRECTUS_ADMIN_EMAIL=admin@aramakisai.com
DIRECTUS_ADMIN_PASSWORD=<管理者パスワード>
DIRECTUS_DB_PASSWORD=<DBパスワード: openssl rand -base64 24>

# ── Directus (staging) ────────────────────────────────────
# 参照: gitops/manifests/staging/directus/external-secret.yaml
DIRECTUS_STAGING_SECRET=<ランダム文字列: openssl rand -base64 24>
DIRECTUS_STAGING_ADMIN_EMAIL=admin@aramakisai.com
DIRECTUS_STAGING_ADMIN_PASSWORD=<管理者パスワード>
DIRECTUS_STAGING_DB_PASSWORD=<DBパスワード: openssl rand -base64 24>

# ── Authentik ─────────────────────────────────────────────
# 参照: gitops/manifests/prod/authentik/external-secret.yaml
AUTHENTIK_SECRET_KEY=<ランダム文字列: openssl rand -base64 36>
AUTHENTIK_DB_PASSWORD=<DBパスワード: openssl rand -base64 24>
