# K3s サーバー設定
# 配置先: /etc/rancher/k3s/config.yaml
# K3s インストール前に配置することでインストーラが読み込む

# CNI: Cilium を使用するため Flannel を無効化
flannel-backend: none

# NetworkPolicy: Cilium が担当するため K3s 組み込みを無効化
disable-network-policy: true

# 不要なコンポーネントを無効化
disable:
  - traefik    # Traefik は gitops (Helm/ArgoCD) で管理するため無効
  - servicelb  # MetalLB / CloudLB を使わないため無効

# Spegel: ノード間イメージキャッシュ (帯域・起動時間の節約)
embedded-registry: true

# kubelet メモリ予約: OS・K3sシステムコンポーネント分を確保し OOM を防ぐ
# eviction-hard: 空きメモリが 200Mi を下回ると優先度の低い Pod を退避させる
# fail-swap-on=false: swap ファイル (roles/swap) 導入により kubelet がデフォルトで
# 起動を拒否するため必須。memorySwap.swapBehavior は未設定 (NoSwap) のままなので
# Pod cgroup は swap 不可。containerd/k3s 本体などホスト側プロセスのみが対象
kubelet-arg:
  - "system-reserved=cpu=100m,memory=300Mi"
  - "kube-reserved=cpu=100m,memory=300Mi"
  - "eviction-hard=memory.available<200Mi"
  - "fail-swap-on=false"

# ノード間通信を Hetzner private network (10.0.1.0/24) に固定する
# kubelet の登録 IP・etcd ピアリング・Pod ネットワークのルーティングが
# private network 経由になり、パブリック IPv6 に余分なトラフィックが流れない
node-ip: "{{ k3s_private_ip }}"

{% if k3s_cluster_init | default(false) %}
# etcd クラスタ初期化 (最初の1台 cp-node のみ true)
cluster-init: true

# TLS SAN: kubeconfig を Tailscale 経由で使う場合に TLS エラーを防ぐ
# K3s デフォルトの証明書は 127.0.0.1 のみ SAN に含まれるため、
# Tailscale MagicDNS と private IP を追加する
tls-san:
  - "{{ ansible_host }}"    # Tailscale MagicDNS (外部 kubectl 用)
  - "{{ k3s_private_ip }}"  # private network IP (ノード間 API アクセス用)
{% else %}
# 追加 server として cp-node のクラスタに参加する
# K3S_URL 環境変数ではなくここで指定することで server モード (k3s.service) でインストールされる
server: "https://{{ hostvars[groups['k3s_server'][0]]['k3s_private_ip'] }}:6443"
{% endif %}
