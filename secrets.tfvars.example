# ============================================================
# secrets.tfvars — Terraform 変数の機密値
# ============================================================
# cp secrets.tfvars.example secrets.tfvars
#
# ここには「Terraform だけが使う variable」を書く。
# 複数ツールをまたぐ値 (k3s_token 等) や
# プロバイダー認証情報 (HCLOUD_TOKEN 等) は .env で管理する。
# ============================================================


# ── Hetzner ───────────────────────────────────────────────────

# ノードに登録する SSH 公開鍵
#   cat ~/.ssh/id_ed25519.pub
ssh_public_key = "ssh-ed25519 AAAA... user@host"


# ── Cloudflare ────────────────────────────────────────────────

# Zone ID: Cloudflare ダッシュボード > aramakisai.com > Overview > 右サイドバー
cloudflare_zone_id = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Account ID: Cloudflare ダッシュボード > 右上アカウントアイコン > アカウントの詳細
cloudflare_account_id = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Cloudflare Tunnel シークレット (任意のランダム文字列)
#   openssl rand -base64 32
cf_tunnel_secret = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"


# ── Cloudflare Access × Authentik OIDC ────────────────────────

# Authentik 管理画面 > Applications > Providers > cloudflare プロバイダーで確認
# 取得後は Infisical にも保存しておくこと
authentik_cf_client_id     = ""
authentik_cf_client_secret = ""
